# GitHub Personal Access Token (required)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Discord Webhook URL (optional - for notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx

# Server Port
PORT=3000

# Cron Schedule (default: 3:00 AM JST)
CRAWL_CRON=0 18 * * *

# Notification Cron (default: 9:00 AM JST)
NOTIFY_CRON=0 0 * * *

# Anthropic API Key (optional - for AI-powered Japanese summaries and search)
ANTHROPIC_API_KEY=
